<script type="text/x-dc" data-dc-script>
class Component extends DCLogic {
  constructor(props) {
    super(props);
    this.state = { faq: {} };
    this.barRef = React.createRef();
    this._onScroll = this._onScroll.bind(this);
  }
  _onScroll() {
    const el = this.barRef.current; if (!el) return;
    const h = document.documentElement;
    const max = (h.scrollHeight - h.clientHeight) || 1;
    const p = Math.min(100, Math.max(0, (h.scrollTop || window.pageYOffset) / max * 100));
    el.style.width = p + '%';
  }
  componentDidMount() { window.addEventListener('scroll', this._onScroll, { passive: true }); this._onScroll(); }
  componentWillUnmount() { window.removeEventListener('scroll', this._onScroll); }
  renderVals() {
    const s = this.state;
    const toc = [
      { label: 'When I stopped asking "what will happen?"', href: '#stopped-asking' },
      { label: "Here's the thing about the future", href: '#the-future' },
      { label: 'How I read tarot reflectively', href: '#how-i-read' },
      { label: "What you're already avoiding", href: '#avoiding' },
      { label: 'The thread you keep', href: '#the-thread' },
      { label: "What this isn't", href: '#what-this-isnt' },
      { label: 'When people ask', href: '#when-people-ask' },
    ];
    const steps = [
      { n: '1', title: 'Ask a real question', body: 'Not "Will I find love?" but "What am I avoiding about how I connect?" Not "What does my future hold?" but "Where am I not taking responsibility for my own life?"' },
      { n: '2', title: 'Get specific, write it down', body: "Something that makes your chest tighten a little because it's a bit more true than you're willing to accept." },
      { n: '3', title: 'Shuffle and hold it', body: 'Hold the question in your heart while the cards move. Let your body feel what your heart is asking.' },
      { n: '4', title: 'Draw, and look first', body: "Before the book or Google or AI. What do you actually see? What colours catch you? What contradicts what you thought this card meant?" },
      { n: '5', title: 'Then read the tradition', body: 'Read what the card is "supposed" to mean, within your deck\u2019s system.' },
      { n: '6', title: 'Ask what it shows you', body: 'What does this card show me about my actual life right now, holding this question, on this day?' },
    ];
    const examples = [
      { name: 'The Tower', tradition: 'Sudden collapse, upheaval', question: 'Where in this relationship am I refusing to see what\u2019s actually crumbling?', glyph: 'radial-gradient(circle at 50% 40%, #e8c98a, #8a7433)' },
      { name: 'The Hermit', tradition: 'Solitude, inward clarity', question: 'What do I need to understand about myself before I move forward?', glyph: 'radial-gradient(circle at 50% 40%, #c6cae2, #5a5b86)' },
    ];
    const faqData = [
      ['Doesn\u2019t tarot require belief?', 'Yes and no. You just need to be willing to sit with a symbol long enough to let it teach you something. Sceptics often make excellent readers, because they don\u2019t project certainty onto the cards.'],
      ['What if the card feels wrong for my question?', "That's often the most useful card. The one that surprises you, the one that contradicts your expectations. That's exactly when reflection happens."],
      ['Can I combine tarot with other methods?', 'Absolutely, but stay reflective. Tell stories, explore symbolism, even divine the future, as long as you stay grounded in what\u2019s true about you, right now.'],
      ['How is tarot different from therapy?', "Therapy is relational: someone qualified helps you metabolise experience. Tarot is a conversation with yourself, mediated by symbols. It's a guide for your intuition, not professional help. It can work alongside it, but if you're in a bad place, seek professional support."],
      ['What if I don\u2019t believe in any of this?', "Then you're asking the right questions. The cards work because they activate your imagination, which activates your intuition. That's not magical. That's how your brain actually works."],
    ];
    const faqs = faqData.map((f, i) => ({
      q: f[0], a: f[1], open: !!s.faq[i], sign: s.faq[i] ? '\u2013' : '+',
      toggle: () => this.setState((st) => ({ faq: Object.assign({}, st.faq, { [i]: !st.faq[i] }) })),
    }));
    const related = [
      { href: 'reading-tarot-with-the-lunar-cycle.dc.html', tag: 'Lunar', title: 'Reading tarot with the lunar cycle', dek: 'How each moon phase shapes your intentions, daily cards and full moon reflections.', bg: 'radial-gradient(circle at 40% 40%, #241e3c, #14112a)' },
      { href: 'Almanac - Tarot Journaling.dc.html', tag: 'Journaling', title: 'Tarot journaling: a practice you can return to', dek: 'A three-line format, prompts, and how to record the echoes that follow.', bg: 'radial-gradient(circle at 55% 40%, #241e3c, #14112a)' },
    ];
    return { barRef: this.barRef, pubDate: '17 July 2026', readTime: '7 min read', toc, steps, examples, faqs, related };
  }
}
</script>
</body>
